# Yardsmith — environment variables (TEMPLATE)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Only SUPABASE_URL and SUPABASE_ANON_KEY are safe in the browser;
# everything else is SERVER-SIDE ONLY (Supabase Edge Function secrets).
# Placeholders below are intentionally non-secret — replace each <...>.

# ── Supabase (client-safe: these two ship in the browser) ──────────────────
# Found in Supabase → Project Settings → API.
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-publishable-anon-key>

# ── Supabase service role (SERVER ONLY — full DB access, bypasses RLS) ──────
# Used by the paddle-webhook function to write subscription state.
# NEVER ship this to the browser. Set as an Edge Function secret:
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<value>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── Anthropic / Claude (SERVER ONLY — powers the AI coach) ──────────────────
# Set as an Edge Function secret, never in client code:
#   supabase secrets set ANTHROPIC_API_KEY=<value>
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Default coach model. Cheaper high-volume options: claude-sonnet-4-6, claude-haiku-4-5
AI_COACH_MODEL=claude-opus-4-8

# ── Paddle (subscriptions — Merchant of Record) ────────────────────────────
# Webhook secret is SERVER ONLY (verifies incoming webhooks):
#   supabase secrets set PADDLE_WEBHOOK_SECRET=<value>
PADDLE_WEBHOOK_SECRET=<your-paddle-webhook-signing-secret>
# Client token is safe in the browser (Paddle.js checkout). Sandbox or production.
PADDLE_CLIENT_TOKEN=<your-paddle-client-side-token>
PADDLE_ENV=sandbox   # 'sandbox' while testing, 'production' when live
# Price IDs for the Pro plan (Paddle → Catalog → Products → Prices).
PADDLE_PRICE_MONTHLY=<your-monthly-price-id>
PADDLE_PRICE_ANNUAL=<your-annual-price-id>
