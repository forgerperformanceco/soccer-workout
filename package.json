{
  "name": "yardsmith",
  "version": "1.0.0",
  "private": true,
  "description": "Yardsmith — golf mass & clubhead-speed PWA, wrapped for the App Store / Play Store via Capacitor.",
  "type": "module",
  "scripts": {
    "build:www": "node scripts/build-www.mjs",
    "sync": "npm run build:www && cap sync",
    "add:ios": "npm run build:www && cap add ios",
    "add:android": "npm run build:www && cap add android",
    "open:ios": "cap open ios",
    "open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@capacitor/push-notifications": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "esbuild": "^0.28.1",
    "playwright-core": "^1.61.1"
  }
}
