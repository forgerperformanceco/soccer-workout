# Secrets — never commit real env values (only .env.example is tracked)
.env
.env.local
.env.*.local

# Supabase local state
supabase/.branches
supabase/.temp

# Node / tooling artifacts
node_modules/
.DS_Store

# Capacitor — www/ is generated by scripts/build-www.mjs; the ios/ and android/
# projects themselves ARE committed, but their copied web bundle + build output
# are regenerated by `cap sync` and stay out of git.
www/
ios/App/Pods/
ios/App/App/public/
ios/DerivedData/
android/.gradle/
android/app/build/
android/build/
android/app/src/main/assets/public/
*.xcuserstate

# Ebook / source transcripts — INPUT ONLY, never redistributed.
# Raw copyrighted text stays out of git; only our original synthesis
# (in the *.md / knowledge.ts files) is committed. README stays tracked.
sources/*
!sources/README.md
